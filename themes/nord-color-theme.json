    },
    "parameter": {
      "foreground": "#D8DEE9",
      "fontStyle": "italic"
    },
    "property": "#D8DEE9",
    "property.declaration": "#88C0D0",
    "property.readonly": {
      "foreground": "#B48EAD",
      "fontStyle": "bold"
    },
    "function": "#88C0D0",
    "function.declaration": "#88C0D0",
    "function.defaultLibrary": "#88C0D0",
    "method": "#88C0D0",
    "method.declaration": "#88C0D0",
    "class": "#8FBCBB",
    "class.declaration": "#8FBCBB",
    "interface": "#8FBCBB",
    "interface.declaration": "#8FBCBB",
    "enum": "#8FBCBB",
    "enumMember": {
      "foreground": "#B48EAD",
      "fontStyle": "bold"
    },
    "type": "#8FBCBB",
    "type.declaration": "#8FBCBB",
    "typeParameter": {
      "foreground": "#8FBCBB",
      "fontStyle": "italic"
    },
    "namespace": "#8FBCBB",
    "struct": "#8FBCBB",
    "decorator": {
      "foreground": "#D08770",
      "fontStyle": "italic"
