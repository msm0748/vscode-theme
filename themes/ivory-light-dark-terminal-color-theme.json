  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#9A8668",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "keyword.operator.new",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7C3F00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "punctuation.separator"],
      "settings": {
        "foreground": "#8B6914"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#2D6A4F"
      }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": {
        "foreground": "#148F77"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#A0522D"
      }
    },
    {
      "name": "Constants & Booleans",
      "scope": [
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#8B0000",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#1A5276"
      }
    },
    {
      "name": "Types & Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#6B3FA0"
      }
    },
    {
      "name": "Type parameters",
      "scope": ["entity.name.type.parameter"],
      "settings": {
        "foreground": "#6B3FA0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#2D6A4F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#3C3C3C"
      }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#5C4E36",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#3C3C3C"
      }
    },
    {
      "name": "Object keys",
      "scope": ["meta.object-literal.key"],
      "settings": {
        "foreground": "#5C3A1A"
      }
    },
    {
      "name": "Namespaces & Modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "storage.modifier.module"
      ],
      "settings": {
        "foreground": "#3C3C3C"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#C8A96E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.string",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#6B5C44"
      }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7C3F00"
      }
    },
    {
      "name": "HTML Attribute names",
      "scope": ["entity.other.attribute-name.html"],
      "settings": {
        "foreground": "#2D6A4F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#1A5276"
      }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#6B3FA0"
      }
    },
    {
      "name": "CSS Values",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#2D6A4F"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#7C3F00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#3C3C3C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#3C3C3C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#7C3F00"
      }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#1A5276"
      }
    },
    {
      "name": "Import / Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#7C3F00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Invalid / Error",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#C0392B",
        "fontStyle": "underline"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#3C3C3C",
    "class": "#6B3FA0",
    "interface": { "foreground": "#2D6A4F", "italic": true },
    "enum": "#148F77",
    "enumMember": "#148F77",
    "function": "#1A5276",
    "method": "#1A5276",
    "property": "#3C3C3C",
    "variable": "#3C3C3C",
    "variable.readonly": { "foreground": "#8B0000" },
    "parameter": { "foreground": "#5C4E36", "italic": true },
    "typeParameter": { "foreground": "#6B3FA0", "italic": true },
    "decorator": { "foreground": "#C8A96E", "italic": true },
    "type": "#6B3FA0",
    "keyword": { "foreground": "#7C3F00", "bold": true },
    "string": "#2D6A4F",
    "number": "#A0522D",
    "comment": { "foreground": "#9A8668", "italic": true }
  }
}
