  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#546E7A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "keyword.operator.new",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF5370",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "punctuation.separator"],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#C3E88D"
      }
    },
    {
      "name": "String escape / Regexp",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "Template literals",
      "scope": [
        "punctuation.definition.template-expression",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#F78C6C"
      }
    },
    {
      "name": "Constants & Booleans",
      "scope": [
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#89DDFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#82AAFF"
      }
    },
    {
      "name": "Types & Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#FFCB6B"
      }
    },
    {
      "name": "Type parameters",
      "scope": ["entity.name.type.parameter"],
      "settings": {
        "foreground": "#C792EA",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#C3E88D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#EEFFFF"
      }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#F78C6C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#EEFFFF"
      }
    },
    {
      "name": "Object keys",
      "scope": ["meta.object-literal.key"],
      "settings": {
        "foreground": "#EEFFFF"
      }
    },
    {
      "name": "Namespaces & Modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "storage.modifier.module"
      ],
      "settings": {
        "foreground": "#EEFFFF"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#C792EA",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.string",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "HTML Tags",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#FF5370"
      }
    },
    {
      "name": "HTML Attribute names",
      "scope": ["entity.other.attribute-name.html"],
      "settings": {
        "foreground": "#C3E88D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#FFCB6B"
      }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "CSS Values",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#C3E88D"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#82AAFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#FFCB6B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#C792EA",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#C3E88D"
      }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#82AAFF"
      }
    },
    {
      "name": "Import / Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#89DDFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Invalid / Error",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#FF5370",
        "fontStyle": "underline"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#EEFFFF",
    "class": "#FFCB6B",
    "interface": { "foreground": "#C3E88D", "italic": true },
    "enum": "#FFCB6B",
    "enumMember": "#89DDFF",
    "function": "#82AAFF",
    "method": "#82AAFF",
    "property": "#EEFFFF",
    "variable": "#EEFFFF",
    "variable.readonly": { "foreground": "#89DDFF" },
    "parameter": { "foreground": "#F78C6C", "italic": true },
    "typeParameter": { "foreground": "#C792EA", "italic": true },
    "decorator": { "foreground": "#C792EA", "italic": true },
    "type": "#FFCB6B",
    "keyword": { "foreground": "#FF5370", "bold": true },
    "string": "#C3E88D",
    "number": "#F78C6C",
    "comment": { "foreground": "#546E7A", "italic": true }
  }
}
