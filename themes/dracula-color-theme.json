  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6272A4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF79C6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest"
      ],
      "settings": {
        "foreground": "#FF79C6",
        "fontStyle": ""
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template"
      ],
      "settings": {
        "foreground": "#F1FA8C"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.numeric.binary"
      ],
      "settings": {
        "foreground": "#BD93F9"
      }
    },
    {
      "name": "Constants and Booleans",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "support.constant",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#BD93F9",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "entity.name.function.member",
        "support.function",
        "support.function.builtin",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#50FA7B"
      }
    },
    {
      "name": "Types and Classes",
      "scope": [
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.module",
        "entity.name.type.alias",
        "entity.other.inherited-class",
        "support.type",
        "support.type.builtin",
        "support.class",
        "support.class.builtin"
      ],
      "settings": {
        "foreground": "#8BE9FD",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.assignment"
      ],
      "settings": {
        "foreground": "#F8F8F2"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "variable.other.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#FFB86C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object Keys / Properties",
      "scope": [
        "meta.object-literal.key",
        "support.type.property-name",
        "variable.other.property",
        "variable.other.object.property",
        "string.json support.type.property-name"
      ],
      "settings": {
        "foreground": "#8BE9FD"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#F8F8F2"
      }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag",
        "punctuation.definition.tag.html",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#FF79C6"
      }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#50FA7B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#50FA7B"
      }
    },
    {
      "name": "CSS Property Names",
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name.css"
      ],
      "settings": {
        "foreground": "#8BE9FD"
      }
    },
    {
      "name": "CSS Property Values",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.color.css",
        "support.constant.font-name.css"
      ],
      "settings": {
        "foreground": "#F8F8F2"
      }
    },
    {
      "name": "CSS Units",
      "scope": [
        "keyword.other.unit.css",
        "keyword.other.unit.rem.css",
        "keyword.other.unit.em.css",
        "keyword.other.unit.px.css"
      ],
      "settings": {
        "foreground": "#FF79C6"
      }
    },
    {
      "name": "Regex and Escape Characters",
      "scope": [
        "string.regexp",
        "constant.character.escape",
        "constant.other.character-class.regexp",
        "keyword.operator.quantifier.regexp",
        "punctuation.definition.group.regexp"
      ],
      "settings": {
        "foreground": "#FFB86C"
      }
    },
    {
      "name": "Import and Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.default"
      ],
      "settings": {
        "foreground": "#FF79C6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "punctuation.decorator",
        "meta.annotation",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#50FA7B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Template String Interpolation",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#FF79C6"
      }
    },
    {
      "name": "Markdown Headings",
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#BD93F9",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FFB86C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#F1FA8C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#8BE9FD"
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#50FA7B"
      }
    },
    {
      "name": "Markdown List",
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#8BE9FD"
      }
    },
    {
      "name": "Markdown Quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#6272A4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSON Property Names",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#8BE9FD"
      }
    },
    {
      "name": "JSON String Values",
      "scope": [
        "string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#F1FA8C"
      }
    },
    {
      "name": "YAML Keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#8BE9FD"
      }
    },
    {
      "name": "YAML Values",
      "scope": [
        "string.unquoted.yaml"
      ],
      "settings": {
        "foreground": "#F1FA8C"
      }
    },
    {
      "name": "Shell Variables",
      "scope": [
        "variable.other.normal.shell",
        "variable.other.special.shell",
        "variable.other.positional.shell",
        "punctuation.definition.variable.shell"
      ],
      "settings": {
        "foreground": "#BD93F9"
      }
    },
    {
      "name": "Inserted (diff)",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#50FA7B"
      }
    },
    {
      "name": "Deleted (diff)",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF5555"
      }
    },
    {
      "name": "Changed (diff)",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#8BE9FD"
      }
    },
    {
      "name": "Invalid / Illegal",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
