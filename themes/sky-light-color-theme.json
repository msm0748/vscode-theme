  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7FA3C4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "keyword.operator.new",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#1565C0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "punctuation.separator"],
      "settings": {
        "foreground": "#1976D2"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#2E7D32"
      }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": {
        "foreground": "#00838F"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#E65100"
      }
    },
    {
      "name": "Constants & Booleans",
      "scope": [
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#B71C1C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#6A1B9A"
      }
    },
    {
      "name": "Types & Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#00838F"
      }
    },
    {
      "name": "Type parameters",
      "scope": ["entity.name.type.parameter"],
      "settings": {
        "foreground": "#00838F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#00838F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#2C3E50"
      }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#37474F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#2C3E50"
      }
    },
    {
      "name": "Object keys",
      "scope": ["meta.object-literal.key"],
      "settings": {
        "foreground": "#1A237E"
      }
    },
    {
      "name": "Namespaces & Modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "storage.modifier.module"
      ],
      "settings": {
        "foreground": "#2C3E50"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#4DB6AC",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.string",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#546E7A"
      }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#1565C0"
      }
    },
    {
      "name": "HTML Attribute names",
      "scope": ["entity.other.attribute-name.html"],
      "settings": {
        "foreground": "#00838F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#6A1B9A"
      }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#1565C0"
      }
    },
    {
      "name": "CSS Values",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#2E7D32"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#1565C0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#2C3E50",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#2C3E50",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#1565C0"
      }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#4A90D9"
      }
    },
    {
      "name": "Import / Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#1565C0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Invalid / Error",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#C62828",
        "fontStyle": "underline"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#2C3E50",
    "class": "#00838F",
    "interface": { "foreground": "#00838F", "italic": true },
    "enum": "#00838F",
    "enumMember": "#00838F",
    "function": "#6A1B9A",
    "method": "#6A1B9A",
    "property": "#2C3E50",
    "variable": "#2C3E50",
    "variable.readonly": { "foreground": "#B71C1C" },
    "parameter": { "foreground": "#37474F", "italic": true },
    "typeParameter": { "foreground": "#00838F", "italic": true },
    "decorator": { "foreground": "#4DB6AC", "italic": true },
    "type": "#00838F",
    "keyword": { "foreground": "#1565C0", "bold": true },
    "string": "#2E7D32",
    "number": "#E65100",
    "comment": { "foreground": "#7FA3C4", "italic": true }
  }
}