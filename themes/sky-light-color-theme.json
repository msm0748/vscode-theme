  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#9DA0AB",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.typeof",
        "keyword.operator.instanceof",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7C5AC2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators & Punctuation",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#6B6E7B",
        "fontStyle": ""
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#3A7D5C"
      }
    },
    {
      "name": "String escape & Regex",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": {
        "foreground": "#1A7A7A"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#B35E2A"
      }
    },
    {
      "name": "Constants & Booleans",
      "scope": [
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#C44040",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#2B6CB0"
      }
    },
    {
      "name": "Types & Classes",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#1A7A7A"
      }
    },
    {
      "name": "Type parameters",
      "scope": ["entity.name.type.parameter"],
      "settings": {
        "foreground": "#1A7A7A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#1A7A7A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#191B20"
      }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#4A4D5A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#191B20"
      }
    },
    {
      "name": "Object keys",
      "scope": ["meta.object-literal.key"],
      "settings": {
        "foreground": "#5A4A8A"
      }
    },
    {
      "name": "Namespaces & Modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "storage.modifier.module"
      ],
      "settings": {
        "foreground": "#191B20"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#7C5AC2",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.string",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#6B6E7B"
      }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7C5AC2"
      }
    },
    {
      "name": "HTML Attribute names",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#2B6CB0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#2B6CB0"
      }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#191B20"
      }
    },
    {
      "name": "CSS Values",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#3A7D5C"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#191B20",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#191B20",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#191B20",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#5A4A8A"
      }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#3182F6"
      }
    },
    {
      "name": "Import / Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#7C5AC2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Invalid / Error",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#C44040",
        "fontStyle": "underline"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json",
        "string.json support.type.property-name"
      ],
      "settings": {
        "foreground": "#5A4A8A"
      }
    },
    {
      "name": "Template string interpolation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#7C5AC2"
      }
    },
    {
      "name": "YAML keys",
      "scope": ["entity.name.tag.yaml"],
      "settings": {
        "foreground": "#5A4A8A"
      }
    },
    {
      "name": "TOML keys",
      "scope": ["support.type.property-name.toml", "entity.name.tag.toml"],
      "settings": {
        "foreground": "#5A4A8A"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#191B20",
    "class": "#1A7A7A",
    "interface": { "foreground": "#1A7A7A", "italic": true },
    "enum": "#1A7A7A",
    "enumMember": "#C44040",
    "function": "#2B6CB0",
    "method": "#2B6CB0",
    "property": "#191B20",
    "variable": "#191B20",
    "variable.readonly": { "foreground": "#C44040", "bold": true },
    "parameter": { "foreground": "#4A4D5A", "italic": true },
    "typeParameter": { "foreground": "#1A7A7A", "italic": true },
    "decorator": { "foreground": "#7C5AC2", "italic": true },
    "type": "#1A7A7A",
    "keyword": { "foreground": "#7C5AC2", "bold": true },
    "string": "#3A7D5C",
    "number": "#B35E2A",
    "comment": { "foreground": "#9DA0AB", "italic": true }
  }
}
