        },
        "vellumTheme.pinkBlossom.stringColor": {
          "type": "string",
          "default": "#2E7D32",
          "description": "String color for Pink Blossom theme",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "vellumTheme.pinkBlossom.functionColor": {
