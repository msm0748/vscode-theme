{
  "name": "vellum-theme",
  "displayName": "Vellum Theme",
  "description": "Warm ivory parchment meets material high contrast dark. Two extremes, one identity.",
  "version": "0.1.0",
  "publisher": "seokmin",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Themes"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/seokmin/vellum-theme"
  },
  "license": "MIT",
  "keywords": [
    "theme",
    "vellum",
    "ivory",
    "material",
    "high contrast",
    "dark",
    "light",
    "parchment"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "themes": [
      {
        "label": "Ivory Light",
        "uiTheme": "vs",
        "path": "./themes/ivory-light-color-theme.json"
      },
      {
        "label": "Material Default High Contrast",
        "uiTheme": "vs-dark",
        "path": "./themes/material-default-hc-color-theme.json"
      },
      {
        "label": "Sky Light",
        "uiTheme": "vs",
        "path": "./themes/sky-light-color-theme.json"
      },
      {
        "label": "Pink Blossom",
        "uiTheme": "vs",
        "path": "./themes/pink-blossom-color-theme.json"
      },
      {
        "label": "Nord",
        "uiTheme": "vs-dark",
        "path": "./themes/nord-color-theme.json"
      },
      {
        "label": "One Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/one-dark-color-theme.json"
      },
      {
        "label": "Dracula",
        "uiTheme": "vs-dark",
        "path": "./themes/dracula-color-theme.json"
      },
      {
        "label": "Monokai",
        "uiTheme": "vs-dark",
        "path": "./themes/monokai-color-theme.json"
      }
    ],
    "commands": [
      {
        "command": "vellumTheme.customize",
        "title": "Ivory Material Theme: Customize Colors"
      },
      {
        "command": "vellumTheme.resetCustomizations",
        "title": "Ivory Material Theme: Reset to Defaults"
      }
    ],
    "configuration": {
      "title": "Vellum Theme",
      "properties": {
        "vellumTheme.ivory.accentColor": {
          "type": "string",
          "default": "#8B7355",
          "description": "Accent color for Ivory Light theme (used in status bar, badges, etc.)",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "vellumTheme.ivory.backgroundColor": {
          "type": "string",
          "default": "#FDFAF3",
          "description": "Editor background color for Ivory Light theme",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "vellumTheme.ivory.keywordColor": {
          "type": "string",
          "default": "#7C3F00",
          "description": "Keyword color for Ivory Light theme",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "vellumTheme.ivory.stringColor": {
          "type": "string",
          "default": "#2D6A4F",
          "description": "String color for Ivory Light theme",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "vellumTheme.ivory.functionColor": {
          "type": "string",
          "default": "#1A5276",
          "description": "Function/method color for Ivory Light theme",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "vellumTheme.materialDefaultHC.accentColor": {
          "type": "string",
          "default": "#82AAFF",
          "description": "Accent color for Material Default High Contrast theme",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "vellumTheme.materialDefaultHC.backgroundColor": {
          "type": "string",
          "default": "#000000",
          "description": "Editor background color for Material Default High Contrast theme",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "vellumTheme.materialDefaultHC.keywordColor": {
          "type": "string",
          "default": "#C792EA",
          "description": "Keyword color for Material Default High Contrast theme",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "vellumTheme.materialDefaultHC.stringColor": {
          "type": "string",
          "default": "#C3E88D",
          "description": "String color for Material Default High Contrast theme",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "vellumTheme.materialDefaultHC.functionColor": {
          "type": "string",
          "default": "#82AAFF",
          "description": "Function/method color for Material Default High Contrast theme",
          "pattern": "^#[0-9A-Fa-f]{6}$"
