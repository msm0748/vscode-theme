          "type": "string",
          "default": "#F5F9FD",
          "description": "Editor background color for Sky Light theme",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "vellumTheme.skyLight.keywordColor": {
          "type": "string",
          "default": "#1565C0",
          "description": "Keyword color for Sky Light theme",
          "pattern": "^#[0-9A-Fa-f]{6}$"
