          "description": "Editor background color for Monokai theme",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "vellumTheme.monokai.keywordColor": {
          "type": "string",
          "default": "#F92672",
          "description": "Keyword color for Monokai theme",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "vellumTheme.monokai.stringColor": {
          "type": "string",
          "default": "#E6DB74",
          "description": "String color for Monokai theme",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "vellumTheme.monokai.functionColor": {
          "type": "string",
